		{"fieldname": "payer", "fieldtype": "Link", "label": "Payer", "options": "Healthcare Payer", "reqd": 1},
		{"fieldname": "insurance_plan", "fieldtype": "Link", "label": "Insurance Plan", "options": "Healthcare Insurance Plan", "reqd": 1},
		{"fieldname": "patient_coverage", "fieldtype": "Link", "label": "Patient Coverage", "options": "Healthcare Patient Coverage"},
		{"fieldname": "service_charge", "fieldtype": "Link", "label": "Service Charge", "options": "Healthcare Service Charge"},
