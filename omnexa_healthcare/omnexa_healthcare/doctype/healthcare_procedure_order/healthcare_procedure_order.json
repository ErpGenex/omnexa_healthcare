		{"fieldname": "encounter", "fieldtype": "Link", "label": "Encounter", "options": "Healthcare Encounter"},
		{"fieldname": "practitioner", "fieldtype": "Link", "label": "Practitioner", "options": "Healthcare Practitioner", "in_list_view": 1},
		{"fieldname": "specialty", "fieldtype": "Link", "label": "Specialty", "options": "Healthcare Specialty"},
		{"fieldname": "procedure", "fieldtype": "Link", "label": "Procedure", "options": "Healthcare Procedure", "reqd": 1, "in_list_view": 1},
		{"fieldname": "appointment", "fieldtype": "Link", "label": "Appointment", "options": "Healthcare Appointment"},
