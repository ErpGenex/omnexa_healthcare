		{"fieldname": "first_visit_rate", "fieldtype": "Currency", "label": "First Visit Rate", "reqd": 1},
		{"fieldname": "follow_up_rate", "fieldtype": "Currency", "label": "Follow-up Rate"},
		{"fieldname": "default_item", "fieldtype": "Link", "label": "Default Item", "options": "Item"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch (optional)", "options": "Branch"}
