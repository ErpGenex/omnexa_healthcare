		{
			"role": "Company Admin",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		}
	],
