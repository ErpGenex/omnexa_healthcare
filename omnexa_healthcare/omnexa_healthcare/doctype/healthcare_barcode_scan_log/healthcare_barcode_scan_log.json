		{
			"fieldname": "item",
			"fieldtype": "Link",
			"label": "Item",
			"options": "Item"
		},
		{
			"fieldname": "verified",
			"fieldtype": "Check",
			"label": "Verified",
			"default": "1"
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1
		}
	]
}
