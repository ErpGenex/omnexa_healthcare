{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Healthcare",
	"name": "Healthcare Drug Interaction Rule",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1
		},
		{
			"role": "Company Admin",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		}
	],
	"track_changes": 1,
	"autoname": "format:HDR-{#####}",
	"fields": [
		{
			"fieldname": "drug_a",
			"fieldtype": "Link",
			"label": "Drug A",
			"options": "Item",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "drug_b",
			"fieldtype": "Link",
			"label": "Drug B",
			"options": "Item",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "severity",
			"fieldtype": "Select",
			"label": "Severity",
			"options": "Minor\nModerate\nMajor\nContraindicated",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "description",
			"fieldtype": "Small Text",
			"label": "Description"
		},
		{
			"default": "1",
			"fieldname": "is_active",
			"fieldtype": "Check",
			"label": "Active"
		}
	]
}
