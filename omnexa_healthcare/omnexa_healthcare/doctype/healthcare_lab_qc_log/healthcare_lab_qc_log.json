{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Healthcare",
	"name": "Healthcare Lab Qc Log",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1
		},
		{
			"role": "Company Admin",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		}
	],
